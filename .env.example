# mySun — Environment Variables
# Bu dosyayı kopyalayıp .env olarak kaydedin ve gerçek değerleri girin.
# NOT: .env dosyası Git'e eklenmez. Bu .env.example dosyasını commit edin.

# Supabase (ileride bulut sync için — şu an uygulamada KULLANILMIYOR)
# Kullanmıyorsanız boş bırakabilirsiniz.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
